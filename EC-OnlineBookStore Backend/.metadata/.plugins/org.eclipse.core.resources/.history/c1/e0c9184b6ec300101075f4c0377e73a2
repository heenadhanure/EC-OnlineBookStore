	@Override
	public UserRegister insertUserRegister(UserRequestDto userRequestDto) {
		logger.info("User register service layer calling/started");
		
		UserRegister user = new UserRegister();
		UserRegisterMongo user1 = new UserRegisterMongo();
		try {
			user.setFirstName(userRequestDto.getFirstName());
			user.setLastName(userRequestDto.getLastName());
			user.setEmail(userRequestDto.getEmail());
			user.setPassword(Base64.getEncoder().encodeToString(userRequestDto.getPassword().getBytes()));
			user.setContactId(userRequestDto.getContactId());
			userRegisterRepo.save(user);
			
			user1.setFirstName(userRequestDto.getFirstName());
			user1.setLastName(userRequestDto.getLastName());
			user1.setEmail(userRequestDto.getEmail());
			user1.setPassword(Base64.getEncoder().encodeToString(userRequestDto.getPassword().getBytes()));
			user1.setContactId(userRequestDto.getContactId());
			userRegisterMongoRepo.save(user1);
			
			logger.info("User register service layer calling ended");
		}catch (Exception e) {
			logger.error("New user creation process failed in BookStore-DB");
			e.printStackTrace();
		}
		return user;
	}

	@Override
	public UserRequest getUserRegisterDetails(Long id) {
		 logger.info("User register service layer calling/started");
		 Optional<UserRegister> byId = userRegisterRepo.findById(id);
         UserRegister userRegister = byId.get();
		 
         logger.info("User register service layer calling ended");
		 return new UserRequest(userRegister.getFirstName(), userRegister.getLastName(),userRegister.getEmail());
	}

	@Override
	public UserRegister checkUserDetails(UserRequestDto userRequestDto) {
		
		logger.info("User register service layer calling/started");
		UserRegister findbyEmail = userRegisterRepo.findByEmail(userRequestDto.getEmail());
		
		if(findbyEmail!=null) {
			logger.info("On Service layer - User found by email");
			String decode = new String(Base64.getDecoder().decode(findbyEmail.getPassword()));
			
			if(decode.equals(userRequestDto.getPassword())) {
				logger.info("Password match success - Login Successfull...!");
				return findbyEmail;
			}
			
		}
		logger.info("User register service layer calling ended");
		return findbyEmail;
		
