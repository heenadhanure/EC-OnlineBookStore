spring:
  application:
    name: APIGateway
  cloud:
    gateway:
      server:
        webflux:
          routes:
            - id: ms-1
              uri: lb://USERREGISTERSERVICE
              predicates:
              - Path=/userregister/**
						- id: ms-2
						  uri: lb://CUSTOMERSERVICE
							predicates:
							- Path=/customer/**
            - id: ms-3
						  uri: lb://BOOKSERVICE
							predicates:
							- Path=/books/**
server:
  port: 7777
