package com.nit.controller;

import java.net.HttpURLConnection;
import java.util.List;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.nit.entity.Book;
import com.nit.exceptions.InternalServerErrorException;
import com.nit.model.BookDto;
import com.nit.model.ResponseMessage;
import com.nit.service.BookService;
import com.nit.utility.Constants;

import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;

@RestController
@RequestMapping("/book")
public class BookController {
	
	public static final Logger logger = LoggerFactory.getLogger(BookController.class);
	
	@Autowired 
	private BookService bookService;
	
	 @Operation(summary = "Create Book",description = "e commerece online books store create book")
	    @ApiResponses({
	     @ApiResponse(responseCode = "201",description = "book created successfully"),
	     @ApiResponse(responseCode = "400",description = "book creation failure"),
	     @ApiResponse(responseCode = "500",description = "Internal server error")
	     })
	@PostMapping("/saveorupdatebook")
	public ResponseEntity<ResponseMessage> createOrUpdateBook(@RequestBody BookDto bookDto){
		logger.info("BookController /savebook API calling...");
		try {
			if(bookDto.getBookTitle()==null || bookDto.getBookPrice()==null || bookDto.getBookTitle().isEmpty()) {
				logger.debug("Recieved user register data : ",bookDto);
				logger.warn("Missing email/password registration request");
				logger.error("User registration email/passsword missing : Bad registration data");
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.FAILED, "Book title or price cannot be empty", bookDto));
			}
			Book createOrUpdateBook = bookService.createOrUpdateBook(bookDto);
			if(createOrUpdateBook!=null) {
				 logger.info("Customer controller layer \"BOOK_STORE_BOOK_SAVE_SUCCESS\".");
				 return ResponseEntity.status(HttpStatus.CREATED).body(new ResponseMessage(HttpURLConnection.HTTP_CREATED, Constants.SUCCESS, "Book saved or updated successfully", createOrUpdateBook));
			}else {
				logger.info("Customer controller layer \"BOOK_STORE_BOOK_SAVE_FAILED\".");
				logger.info("Customer Controller layer \"/booksave\" API is calling ended");
				logger.error("Bad register data : Book creation failed");
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.FAILED, "Book saving or updating Failed", createOrUpdateBook));
			}
		}catch(Exception e) {
			throw new InternalServerErrorException("Something went wrong...!");
		}
	}
	
	 @Operation(summary = "Retrive Book By Id",description = "e commerece online books store retrieve book by id")
	    @ApiResponses({
	     @ApiResponse(responseCode = "201",description = "book retrived successfully"),
	     @ApiResponse(responseCode = "400",description = "book retriving failure"),
	     @ApiResponse(responseCode = "500",description = "Internal server error")
	     })
	@GetMapping("/getBookById/{id}")
	public ResponseEntity<ResponseMessage> getBookById(@PathVariable Long id){
		logger.info("BookController /getBookById/{id} API calling...");
		Book book = bookService.getById(id);
		if(book!=null) {
			logger.debug("Retrived book data : ",book);
			logger.info("Customer controller layer \"BOOK_STORE_BOOK_RETRIVAL_BY_ID_SUCCESS\".");
			return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Book Fetched Successfully", book));
		}else {
			logger.info("Customer controller layer \"BOOK_STORE_BOOK_RETRIVAL_BY_ID_FAILED\".");
			logger.info("BookController /getBookById/{id} API stopped...");
			return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.FAILED, "Error Fetching Book", book));
		}
	}
	 
	 @Operation(summary = "Retrive Books By Title",description = "e commerece online books store retrieve book by title")
	    @ApiResponses({
	     @ApiResponse(responseCode = "201",description = "book retrived successfully"),
	     @ApiResponse(responseCode = "400",description = "book retriving failure"),
	     @ApiResponse(responseCode = "500",description = "Internal server error")
	     })
	 @GetMapping("/getBookByTitle/{bookTitle}")
		public ResponseEntity<ResponseMessage> getBookByTitle(@PathVariable String bookTitle){
			logger.info("BookController /getBookById/{id} API calling...");
			Book book = bookService.getByTitle(bookTitle);
			if(book!=null) {
				logger.debug("Retrived book data : ",book);
				logger.info("Customer controller layer \"BOOK_STORE_BOOK_RETRIVAL_BY_TITLE_SUCCESS\".");
				return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Book Fetched Successfully", book));
			}else {
				logger.info("Customer controller layer \"BOOK_STORE_BOOK_RETRIVAL_BY_TITLE_FAILED\".");
				logger.info("BookController /getBookById/{id} API stopped...");
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.FAILED, "Error Fetching Book", book));
			}
		}
	
	 @Operation(summary = "Retrive All Books",description = "e commerece online books store retrieve all book")
	    @ApiResponses({
	     @ApiResponse(responseCode = "201",description = "books retrived successfully"),
	     @ApiResponse(responseCode = "400",description = "books retriving failure"),
	     @ApiResponse(responseCode = "500",description = "Internal server error")
	     })
	@GetMapping("/getallbooks")
	public ResponseEntity<ResponseMessage> getAllBooks(){
		logger.info("BookController /getallbooks API calling...");
		List<Book> retrieveAllBooks = bookService.retrieveAllBooks();
		if(retrieveAllBooks!=null) {
			logger.debug("Retrived book data : ",retrieveAllBooks);
			logger.info("Customer controller layer \"BOOK_STORE_ALL_BOOKS_RETRIVAL_SUCCESS\".");
			return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Books Fetched Successfully", retrieveAllBooks));
		}else {
			logger.info("Customer controller layer \"BOOK_STORE_ALL_BOOKS_RETRIVAL_FAILED\".");
			logger.info("BookController /getallbooks API stopped...");
			return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.FAILED, "Error Fetching Books", retrieveAllBooks));	
		}
	}
	
	 
	 
	 @DeleteMapping("/deletebyid/{id}")
	 public ResponseEntity<ResponseMessage> deleteBookById(@PathVariable Long id){
		 logger.info("BookController /deletebyid/{id} API calling...");
		 bookService.deleteByBookId(id);		 
		 logger.info("BookController /deletebyid/{id} API stopped...");
		 return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Book deleted..."));

	 }
	 
	 @DeleteMapping("/deletebytitle/{bookTitle}")
	 public ResponseEntity<ResponseMessage> deleteBookByTitle(@PathVariable String bookTitle){
		 logger.info("BookController /deletebytitle/{id} API calling...");
		 bookService.deleteByBookTitle(bookTitle);		 
		 logger.info("BookController /deletebytitle/{id} API stopped...");
		 return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Book deleted..."));

	 }
}
