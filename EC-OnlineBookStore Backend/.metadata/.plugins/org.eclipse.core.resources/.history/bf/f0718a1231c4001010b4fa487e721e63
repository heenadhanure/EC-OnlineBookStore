package com.nit.controller;

import java.net.HttpURLConnection;
import java.util.List;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import com.nit.entity.Cart;
import com.nit.model.ResponseMessage;
import com.nit.service.CartService;
import com.nit.utility.Constants;

import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.responses.ApiResponse;
import io.swagger.v3.oas.annotations.responses.ApiResponses;
import io.swagger.v3.oas.annotations.tags.Tag;

@Tag(name = "UserRegisterController ",description = "UserRegister Regsiter and Login")
@RestController
@RequestMapping("/cart")
public class CartController {
	
	public static final Logger logger = LoggerFactory.getLogger(CartController.class);

	@Autowired
	private CartService cartService;
	
	@Operation(summary = "Add to Cart",description = "e commerece online books store add items to the cart")
    @ApiResponses({
     @ApiResponse(responseCode = "201",description = "item added successfully"),
     @ApiResponse(responseCode = "400",description = "item adding failure"),
     @ApiResponse(responseCode = "500",description = "Internal server error")
     })
	@PostMapping("/addtocart")
	public ResponseEntity<ResponseMessage> addToCart(@RequestParam Long customerId, @RequestParam Long bookId, @RequestParam int quantity){
		logger.info("Cart Controller layer \"/addtocart\" API is calling or started");
		try{
			Cart addItemToCart = cartService.addItemToCart(customerId, bookId, quantity);
			if(addItemToCart!=null) {
			 	logger.info("Message return eco-system=\"BOOK_STORE_ONLINE_ADD_TO_CART_SUCCESS\".");
				return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Item Added to Cart", addItemToCart));
			}else {
				logger.info("Message return eco-system=\"BOOK_STORE_ONLINE_ADD_TO_CART_FAILED\".");		
			 	logger.info("Cart controller layer calling completed");
			 	logger.warn("Cart service return null : registration failed");
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.FAILED, "Adding Item to Cart Failed", addItemToCart));
			}
		}catch(Exception e) {
			return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(new ResponseMessage(HttpURLConnection.HTTP_INTERNAL_ERROR, Constants.FAILED, "Internal Server Error"));			
		}
	}
	
	@GetMapping("/getcartitembyid/{id}")
	public ResponseEntity<ResponseMessage> getCartItemById(@PathVariable Long id){
		try {
			Cart getCartItem = cartService.getCartItem(id);
			if(getCartItem!=null)
				return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Cart Item Retrieved Successfully from Cart", getCartItem));
			else
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.SUCCESS, "Error Fetching Item From Cart", getCartItem));
		}catch(Exception e) {
			return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(new ResponseMessage(HttpURLConnection.HTTP_INTERNAL_ERROR, Constants.FAILED, "Internal Server Error"));
		}
	}
	
	
	@GetMapping("/retrieveitemsfromcart")
	public ResponseEntity<ResponseMessage> retriveAllItemsFromCart(){
		try {
			List<Cart> getAllItems = cartService.getAllItems();
			if(getAllItems!=null)
				return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "All Items Retrieved Successfully from Cart", getAllItems));
			else
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.SUCCESS, "Error Fetching Items From Cart", getAllItems));
		}catch(Exception e) {
			return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(new ResponseMessage(HttpURLConnection.HTTP_INTERNAL_ERROR, Constants.FAILED, "Internal Server Error"));
		}
	}
	
	@PutMapping("/updateitemquantity/{id}")
	public ResponseEntity<ResponseMessage> updateQuantity(@PathVariable Long id, @RequestParam int quantity ){
		try {
			Cart updateItemQuatity = cartService.updateItemQuatity(id, quantity);
			if(updateItemQuatity!=null) {
				return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Item quantity updated in the Cart", updateItemQuatity));
			}else {
				return ResponseEntity.status(HttpStatus.BAD_REQUEST).body(new ResponseMessage(HttpURLConnection.HTTP_BAD_REQUEST, Constants.SUCCESS, "Error updating quantity of item in the cart", updateItemQuatity));
			}
		}catch(Exception e) {
			return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(new ResponseMessage(HttpURLConnection.HTTP_INTERNAL_ERROR, Constants.FAILED, "Internal Server Error"));			
		}
	}
	
	
	@DeleteMapping("/removeitemfromcart/{id}")
	public ResponseEntity<ResponseMessage> deleteItemFromCart(@PathVariable Long id){
		cartService.removeItemFromCart(id);
		return ResponseEntity.status(HttpStatus.OK).body(new ResponseMessage(HttpURLConnection.HTTP_OK, Constants.SUCCESS, "Item Removed From Cart")); 
	}
}
